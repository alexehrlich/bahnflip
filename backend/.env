# Public environment configuration.
# Override any of these in backend/.env.local (never committed).

# Deutsche Bahn API credentials
# Set real values in .env.local to use the live API.
# With PLACEHOLDER values, the backend runs in mock mode automatically.
DB_CLIENT_ID=PLACEHOLDER
DB_API_KEY=PLACEHOLDER

# Set to true to force mock mode regardless of credentials.
DEV_MODE=false
